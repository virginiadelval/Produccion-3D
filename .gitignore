# Exclude dependencies and local env files for backend and source
backend/node_modules/
backend/.env
source/node_modules/
source/.env

# Ignore node_modules in root if any
node_modules/

# Ignore lockfiles and logs generated by npm install
package-lock.json
backend/package-lock.json
source/package-lock.json
npm-debug.log*
yarn-debug.log*
yarn-error.log*
